# ─── RedTeamIQ backend configuration ───────────────────────────────────────
# Copy this file to `.env` and fill in the values from your Azure AI Foundry project.

# Azure AI Foundry project endpoint.
# Found in the Foundry portal → your project → "Project details" → Endpoint.
# Looks like: https://<resource>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://redteamiq-hub.services.ai.azure.com/api/projects/redteamiq-project

# Model deployment names (must match the deployment names in Azure exactly).
# MODEL_EXECUTION  → Recon, Attack Generator, Execution agents (cheap/fast)
# MODEL_REASONING  → Reasoning, Report agents (higher quality)
MODEL_EXECUTION=gpt-4.1-mini
MODEL_REASONING=gpt-4.1-mini 2

# Flask server port.
PORT=5001

# Foundry IQ grounding switch: auto | on | off
#   auto = use the KB when the three KB vars below are set
#   off  = force in-context KB fallback (verify the core pipeline first)
#   on   = force Foundry IQ (errors if KB vars are missing)
FOUNDRY_IQ=auto

# ─── Foundry IQ knowledge base (Azure AI Search agentic retrieval) ───────────
# Leave these blank (or set FOUNDRY_IQ=off) to run with in-context KB fallback.
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
KNOWLEDGE_BASE_NAME=redteamiq-kb
PROJECT_CONNECTION_NAME=redteamiq-kb-mcp
# ARM resource ID of the Foundry project (only needed by the setup scripts):
PROJECT_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/redteamiq-rg/providers/Microsoft.CognitiveServices/accounts/redteamiq-hub/projects/redteamiq-project

# ─── Azure authentication (DefaultAzureCredential) ──────────────────────────
# Easiest: run `az login` on the machine that runs the backend, leave these blank.
# For a service principal / CI, set all three:
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
