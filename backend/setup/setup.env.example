# ─── RedTeamIQ — Foundry IQ setup variables ─────────────────────────────────
# Copy to setup.env and fill in. Sourced by 01_provision.sh and read by the
# Python scripts (02 / 03). These are SETUP-TIME values; the backend's runtime
# .env (one level up) only needs the resulting endpoints/names.

# --- Existing Azure context (your friend already created these) ---
export SUBSCRIPTION_ID=""                      # az account show --query id -o tsv
export RESOURCE_GROUP="redteamiq-rg"
export LOCATION="eastus2"                        # a region that supports agentic retrieval

# Microsoft Foundry account (the resource that hosts your gpt-4.1-mini deployments)
export FOUNDRY_ACCOUNT="redteamiq-hub"
export PROJECT_NAME="redteamiq-project"

# Azure OpenAI / Foundry model endpoint + key (used by the KB for ingestion + planning)
export AOAI_ENDPOINT="https://redteamiq-hub.openai.azure.com"
export AOAI_KEY=""                               # key for the Foundry/AOAI resource
export CHAT_DEPLOYMENT="gpt-4.1-mini"            # existing chat deployment
export EMBEDDING_DEPLOYMENT="text-embedding-3-small"   # YOU MUST DEPLOY THIS (see README)
export EMBEDDING_MODEL="text-embedding-3-small"

# --- Resources this runbook creates ---
export SEARCH_SERVICE="redteamiq-search"         # must be globally unique
export SEARCH_SKU="basic"                        # basic = managed-identity-to-models support
export STORAGE_ACCOUNT="redteamiqkb$RANDOM"      # must be globally unique, 3-24 lowercase
export BLOB_CONTAINER="redteamiq-kb-docs"
export KNOWLEDGE_SOURCE_NAME="redteamiq-blob-ks"
export KNOWLEDGE_BASE_NAME="redteamiq-kb"
export PROJECT_CONNECTION_NAME="redteamiq-kb-mcp"
export KB_API_VERSION="2026-05-01-preview"

# Filled in by 01_provision.sh (exported for the Python scripts):
export SEARCH_ENDPOINT=""                        # https://<search>.search.windows.net
export SEARCH_ADMIN_KEY=""
export PROJECT_RESOURCE_ID=""                    # ARM id of the Foundry project
